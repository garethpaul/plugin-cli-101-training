{
  "name": "@garethpaul/plugin-cli-101-training",
  "description": "Twilio CLI 101 Training",
  "version": "2.0.1",
  "author": "@garethpaul",
  "bugs": "https://github.com/garethpaul/plugin-cli-101-training/issues",
  "dependencies": {
    "@oclif/core": "^1.26.2",
    "@twilio/cli-core": "^8.3.4",
    "chalk": "^4.1.0",
    "clipboardy": "^2.3.0",
    "inquirer": "^8.2.7"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "overrides": {
    "form-data": "4.0.6",
    "js-yaml": "4.2.0"
  },
  "files": [
    "/bin",
    "/oclif.manifest.json",
    "/src"
  ],
  "homepage": "https://github.com/garethpaul/plugin-cli-101-training",
  "keywords": [
    "oclif-plugin"
  ],
  "license": "MIT",
  "oclif": {
    "name": "cli-101-training",
    "commands": "./src/commands",
    "bin": "twilio",
    "repositoryPrefix": "<%- repo %>/blob/<%- version %>/<%- commandPath %>",
    "devPlugins": [
      "@oclif/plugin-help"
    ],
    "topics": {
      "twilio-101-training": {
        "description": "a twilio 101 training"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/garethpaul/plugin-cli-101-training.git"
  },
  "scripts": {
    "build": "node scripts/repository-gate.js build",
    "check": "node scripts/repository-gate.js check",
    "lint": "node scripts/repository-gate.js lint",
    "postpack": "node -e \"require('fs').rmSync('oclif.manifest.json', {force: true})\"",
    "prepack": "oclif manifest && oclif readme",
    "test": "node scripts/repository-gate.js test",
    "version": "oclif readme && git add README.md"
  },
  "devDependencies": {
    "oclif": "^4.23.14"
  }
}
